# ─── Turbo Learning — environment variables ───────────────────────────────────
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local — it is already in .gitignore.
#
# EXPO_PUBLIC_ prefix = inlined by Metro/EAS Build → safe to expose in client
# All other vars = server-side only (Edge Functions, CI, etc.)

# ─── Supabase ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ─── Stripe (client) ────────────────────────────────────────────────────────
# Publishable key — safe for client bundles.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Stripe (server — Edge Functions only) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase service role (Edge Functions / server only) ───────────────────
# Never set EXPO_PUBLIC_ on these — they must never reach the client.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
