{
  "name": "turbo-learning",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@sentry/react-native": "^8.15.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "expo": "~56.0.5",
    "expo-av": "^16.0.8",
    "expo-clipboard": "^56.0.3",
    "expo-constants": "^56.0.16",
    "expo-haptics": "~14.0.0",
    "expo-linking": "^56.0.12",
    "expo-notifications": "~0.31.0",
    "expo-router": "^56.2.7",
    "expo-speech": "^56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "seed": "ts-node scripts/seed-content.ts",
    "test": "jest",
    "ingest:md": "npx tsx tools/ingest/convert.ts",
    "ingest:gdoc": "npx tsx tools/ingest/from-gdoc.ts",
    "validate:content": "python3 tools/validate_lesson.py"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "watchPathIgnorePatterns": [
      ".claude"
    ],
    "modulePathIgnorePatterns": [
      ".claude"
    ],
    "transform": {
      "^.+\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false
          }
        }
      ]
    }
  }
  },
  "private": true
}
